# Railway Environment Variables (do NOT commit .env — use Railway dashboard to set these)
# Add these in Railway → your project → Variables tab:

INSTAGRAM_ACCESS_TOKEN=your_token_here
INSTAGRAM_USER_ID=your_ig_user_id
FACEBOOK_PAGE_ID=your_page_id
GEMINI_API_KEY=your_gemini_key
DEMO_MODE=false
IMAGE_HOST_URL=https://YOUR-APP-NAME.up.railway.app
IMAGE_SERVER_PORT=8888
API_PORT=8000
LOG_LEVEL=INFO
SCHEDULE_HOUR=7
SCHEDULE_MINUTE=0
